###> symfony/framework-bundle ###
# =============================================================================
# SECRETS & CONFIGURATION LOCALES
# =============================================================================
.env
.env.local
/.env.local.php
.env.*.local
.env.test.local
*.key
/config/secrets/prod/prod.decrypt.private.php

# =============================================================================
# DÉPENDANCES & COMPOSER
# =============================================================================
vendor/
/vendor/
node_modules/
/composer.phar

# =============================================================================
# BUILD, CACHE & LOGS (SYMFONY MODERNES - v4 à v7)
# =============================================================================
/var/
/public/bundles/
!/var/cache/
!/var/log/
!/var/cache/.gitkeep
!/var/log/.gitkeep

# Anciennes structures (Symfony 2 / 3) conservées au cas où
/app/cache/*
/app/logs/*
/app/spool/*
/var/sessions/*
!app/cache/.gitkeep
!app/logs/.gitkeep
!var/sessions/.gitkeep

# =============================================================================
# EXÉCUTABLES & ASSISTANCE
# =============================================================================
/bin/*
!bin/console
!bin/symfony_requirements
/.web-server-pid

# =============================================================================
# TESTS, COUVERTURE & QUALITÉ
# =============================================================================
/coverage/
/build/
/.phpunit.result.cache
/phpunit.xml
/app/phpunit.xml

# =============================================================================
# PARAMÈTRES & DOCTRINE BACKUPS
# =============================================================================
/app/config/parameters.yml
/app/config/parameters.ini
/app/bootstrap.php.cache
/var/bootstrap.php.cache
**/Entity/*~

# =============================================================================
# ASSETS & DOSSIERS PUBLICS
# =============================================================================
/web/bundles/
/web/uploads/

# =============================================================================
# SYSTÈME D'EXPLOITATION & IDE (ÉDITEURS DE CODE)
# =============================================================================
.DS_Store
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
