{% extends 'base.html.twig' %}

{% block title %}Étape 2 — Configuration du trajet{% endblock %}

{% block body %}
<h2>Étape 2 : Configuration du trajet</h2>
<p>Départ : <strong>{{ depart.label }}</strong></p>

<form method="POST" action="{{ path('app_arrets') }}" id="form-arrets">

    <fieldset style="margin-bottom: 1.5rem;">
        <legend>Mode de fin de trajet</legend>
        <label>
            <input type="radio" name="mode" value="loin" checked>
            🏁 <strong>Loin</strong> — l'arrêt le plus éloigné du départ en dernier
        </label><br>
        <label>
            <input type="radio" name="mode" value="proche">
            🏠 <strong>Proche</strong> — l'arrêt le plus proche du départ en dernier
        </label>
    </fieldset>

    <div id="arrets-container"></div>

    <button type="button" id="btn-ajouter">+ Ajouter un arrêt</button>
    <br><br>
    <button type="submit" id="btn-calcul" disabled>Calculer la feuille de route →</button>
</form>
{% endblock %}

{% block javascripts %}
<script>
let compteur = 0;

function mettreAJourBoutonSubmit() {
    const blocs = document.querySelectorAll('.arret-bloc');
    const tousValides = [...blocs].every(bloc => {
        return bloc.querySelector('.arret-lat').value !== ''
            && bloc.querySelector('.arret-lon').value !== ''
            && bloc.querySelector('.arret-nom').value.trim() !== '';
    });
    document.getElementById('btn-calcul').disabled = blocs.length === 0 || !tousValides;
}

function renumeroterArrets() {
    const blocs = document.querySelectorAll('.arret-bloc');
    blocs.forEach((bloc, i) => {
        bloc.querySelector('strong').textContent = `Arrêt ${i + 1}`;
    });
    compteur = blocs.length;
}

function ajouterArret() {
    compteur++;
    const container = document.getElementById('arrets-container');
    const div = document.createElement('div');
    div.className = 'arret-bloc';
    div.dataset.index = compteur;
    div.style.cssText = 'border: 1px solid #ddd; padding: 1rem; margin-bottom: 1rem; border-radius: 4px;';
    div.innerHTML = `
        <strong>Arrêt ${compteur}</strong>
        <button type="button" class="btn-supprimer" style="float:right; color:red;">✕ Supprimer</button>
        <br><br>
        <label>Nom de l'arrêt :</label><br>
        <input type="text" name="arret_nom[]" class="arret-nom" placeholder="Ex : Chez grand-mère" required style="width: 300px;">
        <br><br>
        <label>Adresse :</label><br>
        <input type="text" class="arret-label-input" autocomplete="off" placeholder="Ex : 5 rue Victor Hugo, Lyon" style="width: 400px;" required>
        <input type="hidden" name="arret_label[]" class="arret-label">
        <input type="hidden" name="arret_lat[]" class="arret-lat">
        <input type="hidden" name="arret_lon[]" class="arret-lon">
        <ul class="suggestions-list" style="
            list-style:none; padding:0; margin:0;
            border:1px solid #ccc; max-width:400px;
            display:none; position:absolute; background:white; z-index:10;
        "></ul>
    `;

    const labelInput  = div.querySelector('.arret-label-input');
    const labelHidden = div.querySelector('.arret-label');
    const latField    = div.querySelector('.arret-lat');
    const lonField    = div.querySelector('.arret-lon');
    const suggList    = div.querySelector('.suggestions-list');
    const nomField    = div.querySelector('.arret-nom');
    let timer;

    labelInput.addEventListener('input', () => {
        latField.value = '';
        lonField.value = '';
        labelHidden.value = '';
        mettreAJourBoutonSubmit();
        clearTimeout(timer);
        const q = labelInput.value.trim();
        if (q.length < 3) { suggList.style.display = 'none'; return; }
        timer = setTimeout(() => {
            fetch(`https://api-adresse.data.gouv.fr/search/?q=${encodeURIComponent(q)}&limit=5`)
                .then(r => r.json())
                .then(data => {
                    suggList.innerHTML = '';
                    if (!data.features?.length) { suggList.style.display = 'none'; return; }
                    data.features.forEach(f => {
                        const li = document.createElement('li');
                        li.textContent = f.properties.label;
                        li.style.cssText = 'padding:6px 10px; cursor:pointer;';
                        li.addEventListener('mouseover', () => li.style.background = '#f0f0f0');
                        li.addEventListener('mouseout',  () => li.style.background = 'white');
                        li.addEventListener('click', () => {
                            labelInput.value  = f.properties.label;
                            labelHidden.value = f.properties.label;
                            latField.value    = f.geometry.coordinates[1];
                            lonField.value    = f.geometry.coordinates[0];
                            suggList.style.display = 'none';
                            mettreAJourBoutonSubmit();
                        });
                        suggList.appendChild(li);
                    });
                    suggList.style.display = 'block';
                });
        }, 300);
    });

    nomField.addEventListener('input', mettreAJourBoutonSubmit);

    // Fix 2 : suppression avec renumérotation
    div.querySelector('.btn-supprimer').addEventListener('click', () => {
        div.remove();
        renumeroterArrets();
        mettreAJourBoutonSubmit();
    });

    container.appendChild(div);
    renumeroterArrets(); // Fix 2 : renumérotation à chaque ajout aussi
    mettreAJourBoutonSubmit();
}

document.getElementById('btn-ajouter').addEventListener('click', ajouterArret);

document.addEventListener('click', e => {
    if (!e.target.closest('.arret-bloc')) {
        document.querySelectorAll('.suggestions-list').forEach(l => l.style.display = 'none');
    }
});
</script>
{% endblock %}